{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contractility.case-manifest.v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "caseId",
    "createdAt",
    "formationRequest",
    "signedDocuments",
    "newAgreementEdition"
  ],
  "properties": {
    "schemaVersion": { "const": "contractility.case-manifest.v1" },
    "caseId": { "type": "string" },
    "formationRequest": {
      "type": "object",
      "required": ["path", "sha256"]
    },
    "signedDocuments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "order", "path", "sha256", "originalName"]
      }
    },
    "newAgreementEdition": {
      "type": "object",
      "required": ["path", "sha256", "originalName"]
    }
  }
}

